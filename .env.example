# === EchoAtlas SDK Configuration ===
# All are also settable via init({ ... }) in code.

# EchoAtlas API URL (default: https://echo-atlas.com)
ECHOATLAS_API_URL=https://echo-atlas.com

# API key (optional, get one from EchoAtlas Observatory settings)
ECHOATLAS_API_KEY=

# Unique site identifier (e.g. "my-blog", "shop-frontend")
ECHOATLAS_SITE_ID=my-site

# Salt for privacy-compliant IP hashing (generate a random string)
IP_HASH_SALT=

# Override bot detection patterns (comma-separated, optional)
# BOT_UA_PATTERNS=GPTBot,ClaudeBot,CustomBot

# Override trap phrases (comma-separated, optional)
# TRAP_PHRASES=my secret phrase,another trap phrase
